# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
DB_NAME=rondines
DB_USER=rondines
DB_PASSWORD=cambia_esta_password

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=cambia_esta_clave_secreta_larga_y_random
DEBUG=False

PUBLIC_DOMAIN=rondas.lan
PUBLIC_URL=https://rondas.lan

ALLOWED_HOSTS=localhost,127.0.0.1,rondas.lan,192.168.8.6
CSRF_TRUSTED_ORIGINS=https://rondas.lan
CORS_ALLOWED_ORIGINS=https://rondas.lan

# ── Superusuario inicial (se crea solo si no existe) ─────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=cambia_esta_password_admin
DJANGO_SUPERUSER_EMAIL=admin@rondines.local

# ── Configuración de negocio ─────────────────────────────────────────────────
# Horas máximas antes de marcar una ejecución como incompleta
RONDA_MAX_HOURS=12

# ── Caddy (solo para producción con dominio público) ─────────────────────────
ACME_EMAIL=tu@email.com
